# A CMake config file for the library, to be used by external projects

@PACKAGE_INIT@

list(APPEND CMAKE_MODULE_PATH "${CMAKE_CURRENT_LIST_DIR}")

if(TARGET iqm-qdmi-device)
  return()
endif()

include("${CMAKE_CURRENT_LIST_DIR}/iqm-qdmi-device-targets.cmake")

if(NOT iqm-qdmi-device_FIND_QUIETLY)
  message(STATUS "Found IQM QDMI Device version ${iqm-qdmi-device_VERSION}")
endif()
