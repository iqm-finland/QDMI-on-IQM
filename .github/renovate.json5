{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  suppressNotifications: ["prEditedNotification"],
  minimumReleaseAge: "7 days",
  extends: [
    "config:recommended",
    ":gitSignOff",
    "helpers:pinGitHubActionDigestsToSemver",
    ":automergeDigest",
    ":automergeStableNonMajor",
    ":combinePatchMinorReleases",
    ":configMigration",
    ":enablePreCommit",
    ":prConcurrentLimitNone",
    ":prHourlyLimitNone",
  ],
  enabledManagers: [
    "github-actions",
    "pep621",
    "pip_requirements",
    "pre-commit",
  ],
  lockFileMaintenance: {
    enabled: true,
    automerge: true,
  },
  labels: ["dependencies"],
  schedule: ["every weekend"],
  packageRules: [
    {
      matchManagers: ["github-actions"],
      addLabels: ["github-actions"],
      commitMessagePrefix: "⬆\uFE0F\uD83D\uDC68\u200D\uD83D\uDCBB",
    },
    {
      matchManagers: ["pep621", "pip_requirements"],
      addLabels: ["python"],
      commitMessagePrefix: "⬆\uFE0F\uD83D\uDC0D",
    },
    {
      matchManagers: ["pre-commit"],
      addLabels: ["pre-commit"],
      commitMessagePrefix: "⬆\uFE0F\uD83E\uDE9D",
      versioning: "pep440",
    },
    {
      matchUpdateTypes: ["lockFileMaintenance"],
      commitMessagePrefix: "⬆\uFE0F\uD83D\uDD12\uFE0F",
    },
    {
      description: "Group and auto-merge all patch updates",
      groupName: "patch updates",
      matchUpdateTypes: ["patch"],
      matchCurrentVersion: "!/^0\.0/",
      commitMessagePrefix: "⬆\uFE0F\uD83E\uDE79",
      automerge: true,
    },
    {
      description: "Group and auto-merge minor updates of stable dependencies",
      groupName: "minor stable updates",
      matchUpdateTypes: ["minor"],
      matchCurrentVersion: "!/^0\./",
      matchPackageNames: [
        "!munich-quantum-toolkit/*",
        "!munich-quantum-software/*",
      ],
      commitMessagePrefix: "⬆\uFE0F\uD83E\uDE79",
      automerge: true,
    },
    {
      description: "Disable minimum release age checks for closely affiliated GitHub Actions",
      matchManagers: ["github-actions"],
      matchPackageNames: [
        "munich-quantum-toolkit/*",
        "munich-quantum-software/*",
        "iqm-finland/*",
      ],
      minimumReleaseAge: null,
    },
    {
      description: "Disable minimum release age checks for closely affiliated Python packages",
      matchDatasources: ["pypi"],
      matchPackageNames: ["mqt*", "iqm*"],
      minimumReleaseAge: null,
    },
  ],
}
