# ===========================================
# QDMI on IQM
# Environment Variables Configuration
# ===========================================
# Copy this file to `.env` and fill in your values:
#   cp .env.example .env

# -------------------------------------------
# IQM Quantum Server Configuration
# -------------------------------------------

# URL of the IQM quantum server
# Examples:
#   - Resonance:  https://resonance.iqm.tech
#IQM_BASE_URL=

# -------------------------------------------
# Quantum Computer Selection
# -------------------------------------------

# Specify which quantum computer to use (optional)
# Use EITHER qc_id (UUID) OR qc_alias (name:variant)

# Quantum Computer ID (UUID format)
# Example: IQM_QC_ID=12345678-1234-1234-1234-123456789abc
#IQM_QC_ID=

# Quantum Computer Alias (name[:variant] format)
# Examples:
#   - emerald:mock      # IQM Emerald mock device
#   - garnet            # IQM Garnet production device
# Example: IQM_QC_ALIAS=emerald:mock
#IQM_QC_ALIAS=

# -------------------------------------------
# Authentication Configuration
# Choose ONE of the following methods:
# -------------------------------------------

# Method 1: Bearer Token Authentication
# Provide a single authentication token
# Example: IQM_TOKEN=your_bearer_token_here
#IQM_TOKEN=

# Method 2: Tokens File Authentication
# Path to a JSON file containing authentication tokens
# Example: IQM_TOKENS_FILE=/path/to/tokens.json
#IQM_TOKENS_FILE=

# -------------------------------------------
# Offloader Configuration
# -------------------------------------------

# Directory for job files (circuit QPY, operator PKL files)
# Default: ~/.qdmi_jobs (user's home directory under .qdmi_jobs)
#IQM_JOBS_DIR=
